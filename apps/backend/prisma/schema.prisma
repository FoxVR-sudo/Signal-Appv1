generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  phone       String   @unique
  role        String
  createdAt   DateTime @default(now())
  reports     Report[]
}

model Report {
  id               String   @id @default(cuid())
  citizenId        String
  citizen          User     @relation(fields: [citizenId], references: [id])
  photoUrl         String
  lat              Float
  lng              Float
  gpsAccuracyM     Float
  capturedAtDevice DateTime
  receivedAtServer DateTime @default(now())
  status           String   @default("submitted")
}
